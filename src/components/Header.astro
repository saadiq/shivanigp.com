---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const navItems = [
  { label: 'Home', href: base },
  { label: 'About', href: `${base}about/` },
  { label: 'Work', href: `${base}work/` },
  { label: 'Connect', href: `${base}connect/` },
];
---

<header class="header">
  <nav class="container header__nav">
    <a href={base} class="header__logo">Shivani Garg Patel</a>
    <input type="checkbox" id="nav-toggle" class="header__toggle-input sr-only" aria-label="Toggle navigation" />
    <label for="nav-toggle" class="header__toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </label>
    <ul class="header__links">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['header__link', { 'header__link--active': pathname === item.href }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 250, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-gray-200);
    height: var(--header-height);
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-black);
  }

  .header__logo:hover {
    color: var(--color-blue);
  }

  .header__links {
    display: flex;
    list-style: none;
    gap: 2rem;
  }

  .header__link {
    font-size: 0.85rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gray-600);
    padding: 0.25rem 0;
    transition: color 0.2s;
  }

  .header__link:hover {
    color: var(--color-black);
  }

  .header__link--active {
    color: var(--color-black);
    font-weight: 500;
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    z-index: 10;
  }

  .header__toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-black);
    transition: transform 0.3s, opacity 0.3s;
  }

  .header__toggle-input { display: none; }

  @media (max-width: 768px) {
    .header__toggle {
      display: flex;
    }

    .header__links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 70%;
      max-width: 300px;
      height: 100vh;
      flex-direction: column;
      background: var(--color-white);
      padding: 5rem 2rem 2rem;
      gap: 1.5rem;
      box-shadow: -4px 0 20px rgba(0,0,0,0.1);
      transition: right 0.3s ease;
    }

    .header__toggle-input:checked ~ .header__links {
      right: 0;
    }

    .header__toggle-input:checked ~ .header__toggle span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .header__toggle-input:checked ~ .header__toggle span:nth-child(2) {
      opacity: 0;
    }

    .header__toggle-input:checked ~ .header__toggle span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }
  }
</style>
